<style>
:root {
  --bg: #060b14;
  --surface: #0d1626;
  --surface2: #132035;
  --surface3: #1a2d47;
  --border: #1e3354;
  --border2: #2a4a6e;
  --accent: #e8b84b;
  --accent-dim: rgba(232,184,75,0.15);
  --red: #d63031;
  --green: #00b894;
  --blue: #0984e3;
  --text: #e8f0ff;
  --text2: #6b8ab0;
  --text3: #3d5a7a;
  --gold: #ffd700;
  --silver: #b0bec5;
  --bronze: #cd7f32;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Barlow', sans-serif;
  min-height: 100vh;
  overflow-x: hidden;
}

body::before {
  content: '';
  position: fixed;
  inset: 0;
  background:
    radial-gradient(ellipse 80% 50% at 20% 10%, rgba(232,184,75,0.04) 0%, transparent 60%),
    radial-gradient(ellipse 60% 40% at 80% 90%, rgba(9,132,227,0.05) 0%, transparent 60%);
  pointer-events: none;
  z-index: 0;
}

/* ===== LOADING ===== */
#loading-screen {
  position: fixed; inset: 0;
  background: var(--bg);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  z-index: 9999;
  gap: 20px;
}
.loader-logo {
  font-family: 'Bebas Neue', cursive;
  font-size: 52px;
  letter-spacing: 6px;
  color: var(--accent);
  animation: pulse 1.5s ease-in-out infinite;
}
.loader-sub {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 14px;
  letter-spacing: 4px;
  color: var(--text2);
  text-transform: uppercase;
}
.loader-bar {
  width: 200px; height: 3px;
  background: var(--surface3);
  border-radius: 2px;
  overflow: hidden;
}
.loader-bar-fill {
  height: 100%;
  background: var(--accent);
  border-radius: 2px;
  animation: load 1.5s ease-in-out infinite;
}
@keyframes load { 0%{width:0;margin-left:0} 50%{width:100%;margin-left:0} 100%{width:0;margin-left:100%} }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.6} }

/* ===== HEADER ===== */
header {
  position: sticky; top: 0; z-index: 200;
  background: rgba(6,11,20,0.95);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
  box-shadow: 0 4px 40px rgba(0,0,0,0.6);
}
.header-inner {
  max-width: 1300px;
  margin: 0 auto;
  padding: 0 20px;
  height: 62px;
  display: flex;
  align-items: center;
  gap: 20px;
}
.logo {
  display: flex; align-items: center; gap: 12px;
  text-decoration: none;
}
.logo-box {
  background: var(--accent);
  color: #000;
  font-family: 'Bebas Neue', cursive;
  font-size: 13px;
  letter-spacing: 1px;
  padding: 4px 8px;
  border-radius: 4px;
  line-height: 1.3;
  text-align: center;
}
.logo-title {
  font-family: 'Bebas Neue', cursive;
  font-size: 22px;
  letter-spacing: 3px;
  color: var(--text);
}
.logo-title span { color: var(--accent); }

nav {
  display: flex; gap: 2px;
  margin-left: auto;
}
.nav-btn {
  background: transparent;
  border: 1px solid transparent;
  color: var(--text2);
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  padding: 7px 16px;
  cursor: pointer;
  border-radius: 6px;
  transition: all 0.2s;
  white-space: nowrap;
}
.nav-btn:hover { color: var(--text); border-color: var(--border2); }
.nav-btn.active { background: var(--accent-dim); color: var(--accent); border-color: rgba(232,184,75,0.3); }
.nav-btn.admin-btn { color: var(--red); }
.nav-btn.admin-btn.active { background: rgba(214,48,49,0.1); color: var(--red); border-color: rgba(214,48,49,0.3); }

.user-pill {
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 5px 14px 5px 10px;
  display: flex; align-items: center; gap: 8px;
  font-size: 13px;
  cursor: pointer;
  transition: all 0.2s;
  white-space: nowrap;
}
.user-pill:hover { border-color: var(--accent); }
.user-avatar {
  width: 26px; height: 26px;
  background: var(--accent);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Bebas Neue', cursive;
  font-size: 14px;
  color: #000;
  flex-shrink: 0;
}

/* ===== MAIN ===== */
main {
  max-width: 1300px;
  margin: 0 auto;
  padding: 28px 20px 80px;
  position: relative; z-index: 1;
}

.page { display: none; }
.page.active { display: block; animation: fadeIn 0.3s ease; }
@keyframes fadeIn { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }

/* ===== AUTH SCREEN ===== */
.auth-screen {
  min-height: 80vh;
  display: flex; align-items: center; justify-content: center;
}
.auth-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 48px 40px;
  width: 100%;
  max-width: 440px;
  box-shadow: 0 20px 60px rgba(0,0,0,0.5);
}
.auth-header {
  text-align: center;
  margin-bottom: 36px;
}
.auth-wm-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--accent-dim);
  border: 1px solid rgba(232,184,75,0.3);
  border-radius: 30px;
  padding: 6px 16px;
  margin-bottom: 20px;
}
.auth-wm-badge span {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 12px;
  letter-spacing: 3px;
  color: var(--accent);
  text-transform: uppercase;
}
.auth-title {
  font-family: 'Bebas Neue', cursive;
  font-size: 44px;
  letter-spacing: 4px;
  line-height: 1;
}
.auth-title .highlight { color: var(--accent); }
.auth-subtitle {
  color: var(--text2);
  font-size: 14px;
  margin-top: 8px;
  font-family: 'Barlow Condensed', sans-serif;
  letter-spacing: 1px;
}

.form-group { margin-bottom: 16px; }
.form-label {
  display: block;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--text2);
  margin-bottom: 8px;
}
.form-input {
  width: 100%;
  background: var(--surface2);
  border: 1.5px solid var(--border);
  border-radius: 8px;
  color: var(--text);
  font-family: 'Barlow', sans-serif;
  font-size: 15px;
  padding: 12px 16px;
  outline: none;
  transition: all 0.2s;
}
.form-input:focus { border-color: var(--accent); background: var(--surface3); }
.form-input::placeholder { color: var(--text3); }

.btn-primary {
  width: 100%;
  background: var(--accent);
  border: none;
  border-radius: 8px;
  color: #000;
  cursor: pointer;
  font-family: 'Bebas Neue', cursive;
  font-size: 20px;
  letter-spacing: 3px;
  padding: 14px;
  transition: all 0.2s;
  margin-top: 8px;
}
.btn-primary:hover { background: #f0ca5a; transform: translateY(-2px); box-shadow: 0 8px 20px rgba(232,184,75,0.3); }
.btn-primary:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

.auth-toggle {
  text-align: center;
  margin-top: 20px;
  font-size: 13px;
  color: var(--text2);
}
.auth-toggle a {
  color: var(--accent);
  cursor: pointer;
  text-decoration: none;
}
.auth-toggle a:hover { text-decoration: underline; }

.error-msg {
  background: rgba(214,48,49,0.1);
  border: 1px solid rgba(214,48,49,0.3);
  border-radius: 6px;
  color: #ff7675;
  font-size: 13px;
  padding: 10px 14px;
  margin-bottom: 16px;
  display: none;
}
.error-msg.show { display: block; }

/* ===== SECTION TITLES ===== */
.page-title {
  font-family: 'Bebas Neue', cursive;
  font-size: 36px;
  letter-spacing: 4px;
  color: var(--text);
  margin-bottom: 24px;
  display: flex;
  align-items: center;
  gap: 14px;
}
.page-title::after {
  content: '';
  flex: 1;
  height: 1px;
  background: linear-gradient(90deg, var(--border), transparent);
}

/* ===== TABELLE ===== */
.tabelle-wrap {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 16px;
  overflow: hidden;
}
.tabelle-topbar {
  padding: 20px 24px;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 12px;
}
.legend {
  display: flex; gap: 16px; flex-wrap: wrap;
}
.legend-item {
  display: flex; align-items: center; gap: 6px;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 12px;
  letter-spacing: 1px;
  color: var(--text2);
}
.legend-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
}
.ld-exact { background: var(--green); }
.ld-tend { background: var(--blue); }
.ld-wrong { background: var(--red); }
.ld-open { background: var(--border2); }

table { width: 100%; border-collapse: collapse; }
th {
  background: var(--surface2);
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--text2);
  padding: 12px 20px;
  text-align: left;
  white-space: nowrap;
}
th.c { text-align: center; }
td {
  padding: 14px 20px;
  border-bottom: 1px solid rgba(30,51,84,0.6);
  vertical-align: middle;
}
tr:last-child td { border-bottom: none; }
tr:hover td { background: rgba(255,255,255,0.015); }
.rank-num {
  font-family: 'Bebas Neue', cursive;
  font-size: 24px;
  text-align: center;
  width: 50px;
}
.r1 { color: var(--gold); }
.r2 { color: var(--silver); }
.r3 { color: var(--bronze); }
.player-name-cell { font-family: 'Barlow Condensed', sans-serif; font-size: 18px; font-weight: 700; }
.player-alias { font-size: 12px; color: var(--text2); font-family: 'Barlow', sans-serif; font-weight: 400; }
.pts-big { font-family: 'Bebas Neue', cursive; font-size: 30px; color: var(--accent); text-align: center; }
.num-cell { text-align: center; font-family: 'Barlow Condensed', sans-serif; font-size: 16px; font-weight: 700; }
.dots-row { display: flex; flex-wrap: wrap; gap: 3px; max-width: 200px; }
.dot { width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0; }
.d-exact { background: var(--green); }
.d-tend { background: var(--blue); }
.d-wrong { background: var(--red); }
.d-open { background: var(--border2); }
.me-row td { background: rgba(232,184,75,0.04) !important; }

/* ===== TIPPS ===== */
.gruppe-header {
  display: flex; align-items: center; gap: 14px;
  margin: 36px 0 16px;
}
.gruppe-badge {
  background: var(--accent);
  color: #000;
  font-family: 'Bebas Neue', cursive;
  font-size: 20px;
  width: 40px; height: 40px;
  display: flex; align-items: center; justify-content: center;
  border-radius: 8px;
  flex-shrink: 0;
}
.gruppe-info h3 {
  font-family: 'Bebas Neue', cursive;
  font-size: 20px;
  letter-spacing: 2px;
}
.gruppe-info p { font-size: 12px; color: var(--text2); font-family: 'Barlow Condensed', sans-serif; letter-spacing: 1px; }

.spiele-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
  gap: 10px;
}

.spiel-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 16px 18px;
  position: relative;
  overflow: hidden;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.spiel-card:hover { border-color: var(--border2); }
.spiel-card.locked { opacity: 0.7; }

.spiel-top {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 12px;
}
.spiel-meta { font-size: 11px; color: var(--text2); font-family: 'Barlow Condensed', sans-serif; letter-spacing: 1px; }
.locked-badge {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 10px;
  letter-spacing: 1px;
  background: rgba(214,48,49,0.15);
  color: var(--red);
  border: 1px solid rgba(214,48,49,0.3);
  border-radius: 10px;
  padding: 2px 8px;
  display: none;
}
.spiel-card.locked .locked-badge { display: inline-block; }

.spiel-teams {
  display: flex; align-items: center; gap: 8px;
}
.team-block {
  flex: 1;
  display: flex; align-items: center; gap: 8px;
}
.team-block.away { flex-direction: row-reverse; }
.team-flag { font-size: 24px; flex-shrink: 0; }
.team-n {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 16px;
  font-weight: 700;
  letter-spacing: 0.3px;
}
.team-block.home .team-n { text-align: right; }
.team-block.away .team-n { text-align: left; }

.score-box {
  background: var(--surface2);
  border: 1.5px solid var(--border);
  border-radius: 10px;
  display: flex; align-items: center; gap: 4px;
  padding: 6px 10px;
  transition: border-color 0.2s;
  flex-shrink: 0;
}
.score-box:focus-within { border-color: var(--accent); }
.score-box.has-result { border-color: rgba(0,184,148,0.4); }
.score-inp {
  background: transparent;
  border: none;
  color: var(--text);
  font-family: 'Bebas Neue', cursive;
  font-size: 28px;
  outline: none;
  text-align: center;
  width: 34px;
  -moz-appearance: textfield;
}
.score-inp::-webkit-inner-spin-button,
.score-inp::-webkit-outer-spin-button { -webkit-appearance: none; }
.score-inp:disabled { color: var(--text2); }
.score-sep { color: var(--text3); font-family: 'Bebas Neue', cursive; font-size: 22px; }

.tipp-footer {
  display: flex; justify-content: space-between; align-items: center;
  margin-top: 10px;
}
.status-badge {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 10px; letter-spacing: 1.5px;
  text-transform: uppercase;
  padding: 2px 10px;
  border-radius: 10px;
}
.sb-exact { background: rgba(0,184,148,0.15); color: var(--green); border: 1px solid rgba(0,184,148,0.3); }
.sb-tend  { background: rgba(9,132,227,0.15); color: var(--blue); border: 1px solid rgba(9,132,227,0.3); }
.sb-wrong { background: rgba(214,48,49,0.15); color: var(--red); border: 1px solid rgba(214,48,49,0.3); }
.ergebnis-display {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 12px;
  color: var(--text2);
}
.ergebnis-display strong { color: var(--text); }

/* ===== PROGRESS BAR ===== */
.progress-bar {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 18px 24px;
  margin-bottom: 24px;
  display: flex; align-items: center; gap: 20px; flex-wrap: wrap;
}
.progress-label { font-family: 'Barlow Condensed', sans-serif; font-size: 13px; letter-spacing: 1.5px; color: var(--text2); text-transform: uppercase; flex-shrink: 0; }
.progress-track { flex: 1; min-width: 100px; height: 6px; background: var(--surface3); border-radius: 3px; overflow: hidden; }
.progress-fill { height: 100%; background: linear-gradient(90deg, var(--accent), #f0ca5a); border-radius: 3px; transition: width 0.5s; }
.progress-count { font-family: 'Bebas Neue', cursive; font-size: 20px; color: var(--accent); flex-shrink: 0; }

/* ===== ADMIN ===== */
.admin-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(380px, 1fr)); gap: 10px; }
.ergebnis-admin-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 16px 18px;
}
.era-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px; }
.era-teams { font-family: 'Barlow Condensed', sans-serif; font-size: 17px; font-weight: 700; display: flex; align-items: center; gap: 6px; }
.era-meta { font-size: 11px; color: var(--text2); margin-top: 2px; }
.era-inputs { display: flex; align-items: center; gap: 8px; }
.era-score-box {
  background: var(--surface2);
  border: 1.5px solid var(--border);
  border-radius: 8px;
  display: flex; align-items: center; gap: 4px;
  padding: 6px 12px;
  transition: border-color 0.2s;
}
.era-score-box:focus-within { border-color: var(--green); }
.era-inp {
  background: transparent; border: none;
  color: var(--text);
  font-family: 'Bebas Neue', cursive;
  font-size: 26px;
  outline: none;
  text-align: center;
  width: 32px;
  -moz-appearance: textfield;
}
.era-inp::-webkit-inner-spin-button, .era-inp::-webkit-outer-spin-button { -webkit-appearance: none; }
.era-save-btn {
  background: var(--green);
  border: none;
  border-radius: 6px;
  color: #000;
  cursor: pointer;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 1px;
  padding: 8px 14px;
  transition: all 0.2s;
  white-space: nowrap;
}
.era-save-btn:hover { background: #00d2a0; }
.era-saved { color: var(--green); font-size: 12px; font-family: 'Barlow Condensed', sans-serif; display: none; }

/* Admin Mitarbeiter */
.mitarbeiter-table-wrap {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 16px;
  overflow: hidden;
  margin-top: 24px;
}
.btn-sm {
  background: transparent;
  border: 1px solid var(--border);
  border-radius: 6px;
  color: var(--text2);
  cursor: pointer;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 12px;
  letter-spacing: 1px;
  padding: 5px 12px;
  transition: all 0.2s;
}
.btn-sm:hover { border-color: var(--accent); color: var(--accent); }
.btn-sm.danger:hover { border-color: var(--red); color: var(--red); }

/* ===== TOAST ===== */
#toast {
  position: fixed; bottom: 28px; right: 24px; z-index: 9999;
  background: var(--surface3);
  border: 1px solid var(--border2);
  border-radius: 10px;
  padding: 12px 20px;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 14px;
  letter-spacing: 1px;
  box-shadow: 0 8px 30px rgba(0,0,0,0.4);
  transform: translateY(20px); opacity: 0;
  transition: all 0.3s;
  pointer-events: none;
  max-width: 300px;
}
#toast.show { transform: translateY(0); opacity: 1; }
#toast.success { border-color: rgba(0,184,148,0.5); }
#toast.error { border-color: rgba(214,48,49,0.5); }

/* ===== MISC ===== */
.empty { text-align: center; padding: 60px 20px; color: var(--text2); }
.empty h3 { font-family: 'Bebas Neue', cursive; font-size: 28px; letter-spacing: 2px; margin-bottom: 8px; }

.btn-outline {
  background: transparent;
  border: 1.5px solid var(--border2);
  border-radius: 8px;
  color: var(--text2);
  cursor: pointer;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 13px;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  padding: 9px 20px;
