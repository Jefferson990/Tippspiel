function dbRef(path) { return window._ref(window._db, path); }
async function dbGet(path) {
  const snap = await window._get(dbRef(path));
  return snap.exists() ? snap.val() : null;
}
async function dbSet(path, val) { await window._set(dbRef(path), val); }
async function dbUpdate(path, val) { await window._update(dbRef(path), val); }

// ========================================================
