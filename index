  document.getElementById('app-header').style.display = '';
  document.getElementById('app-main').style.display = '';

  // Gespeicherte Session?
  const saved = localStorage.getItem('hetec_wm_nick');
  if (saved) {
    const user = await dbGet('spieler/' + saved);
    if (user) {
      loginUser(saved, user);
      return;
    } else {
      localStorage.removeItem('hetec_wm_nick');
    }
  }
  showAuthPage();
});

