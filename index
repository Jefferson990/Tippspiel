}

async function doLogin() {
  const nick = document.getElementById('login-nick').value.trim();
  const errEl = document.getElementById('login-error');
  if (!nick) { showErr(errEl, 'Bitte Nickname eingeben'); return; }

  const user = await dbGet('spieler/' + nick);
  if (!user) {
    showErr(errEl, 'Nickname nicht gefunden. Bitte registrieren.');
    return;
  }
  loginUser(nick, user);
}

async function doRegister() {
  const nick = document.getElementById('reg-nick').value.trim();
  const vorname = document.getElementById('reg-first').value.trim();
  const nachname = document.getElementById('reg-last').value.trim();
  const errEl = document.getElementById('reg-error');

  if (!nick || !vorname || !nachname) { showErr(errEl, 'Alle Felder ausfüllen'); return; }
  if (nick.length < 2) { showErr(errEl, 'Nickname mind. 2 Zeichen'); return; }
  if (!/^[a-zA-Z0-9_\-äöüÄÖÜ]+$/.test(nick)) { showErr(errEl, 'Nickname: nur Buchstaben, Zahlen, _ und -'); return; }

  const existing = await dbGet('spieler/' + nick);
  if (existing) { showErr(errEl, 'Dieser Nickname ist bereits vergeben'); return; }

  const userData = { vorname, nachname, registriert: new Date().toISOString() };
  await dbSet('spieler/' + nick, userData);
  loginUser(nick, userData);
  showToast('✅ Willkommen, ' + nick + '!', 'success');
}

function loginUser(nick, userData) {
  currentUser = { nick, ...userData };
  localStorage.setItem('hetec_wm_nick', nick);

  document.getElementById('user-nick-display').textContent = nick;
  document.getElementById('user-avatar').textContent = nick[0].toUpperCase();
  document.getElementById('main-nav').style.display = '';
  document.getElementById('user-info').style.display = '';

  showPage('tabelle', document.querySelector('.nav-btn'));
  loadTabelle();
}

function logout() {
  if (!confirm('Abmelden?')) return;
  currentUser = null;
  adminLoggedIn = false;
  localStorage.removeItem('hetec_wm_nick');
  document.getElementById('admin-nav-btn').style.display = 'none';
  document.getElementById('admin-content').style.display = 'none';
  document.getElementById('admin-login-wrap').style.display = '';
  showAuthPage();
}

function showErr(el, msg) { el.textContent = msg; el.classList.add('show'); }

// ========================================================
// NAVIGATION
// ========================================================
function showPage(name, btn) {
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  if (btn) btn.classList.add('active');
  showPageDirect(name);

  if (name === 'tabelle') loadTabelle();
  if (name === 'tipps') loadTipps();
  if (name === 'admin') initAdminPage();
}

function showPageDirect(name) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-' + name).classList.add('active');
}

// ========================================================
// PUNKTE BERECHNUNG
// ========================================================
function calcPts(t, e) {
  if (t.h === '' || t.g === '' || t.h === undefined || t.g === undefined) return null;
  if (e.h === '' || e.g === '' || e.h === undefined || e.g === undefined) return null;
  const th = +t.h, tg = +t.g, eh = +e.h, eg = +e.g;
  if (th === eh && tg === eg) return 3;
  if (Math.sign(th - tg) === Math.sign(eh - eg)) return 1;
  return 0;
}

// ========================================================
// TABELLE
// ========================================================
async function loadTabelle() {
  const bodyEl = document.getElementById('tabelle-body');
  bodyEl.innerHTML = '<div class="empty"><h3>Lade...</h3></div>';

  const [alleSpielaer, alleTipps, ergebnisse] = await Promise.all([
    dbGet('spieler'),
    dbGet('tipps'),
    dbGet('ergebnisse'),
  ]);

  if (!alleSpielaer) { bodyEl.innerHTML = '<div class="empty"><h3>Keine Spieler</h3></div>'; return; }

  ergebnisseCache = ergebnisse || {};

  const rows = Object.entries(alleSpielaer).map(([nick, info]) => {
    const myTipps = (alleTipps && alleTipps[nick]) ? alleTipps[nick] : {};
    let punkte = 0, exakt = 0, tendenz = 0, falsch = 0, offen = 0;
    const dots = [];

    ALL_SPIELE.forEach(s => {
      const t = myTipps[s.id] || {};
      const e = ergebnisseCache[s.id] || {};
      const pts = calcPts(t, e);
      if (pts === null) { offen++; dots.push('o'); }
      else if (pts === 3) { exakt++; punkte += 3; dots.push('e'); }
      else if (pts === 1) { tendenz++; punkte += 1; dots.push('t'); }
      else { falsch++; dots.push('w'); }
    });

    return { nick, info, punkte, exakt, tendenz, falsch, offen, dots };
  });

  rows.sort((a, b) => b.punkte - a.punkte || b.exakt - a.exakt || b.tendenz - a.tendenz);

  const rankIcons = ['🥇','🥈','🥉'];

  let html = `<table><thead><tr>
    <th class="c">#</th>
    <th>Spieler</th>
    <th class="c">Punkte</th>
    <th class="c" title="Exakt">✓</th>
    <th class="c" title="Tendenz">~</th>
    <th class="c" title="Falsch">✗</th>
    <th>Verlauf</th>
  </tr></thead><tbody>`;

  rows.forEach((r, i) => {
    const rank = i + 1;
    const cls = rank <= 3 ? `r${rank}` : '';
    const isMe = currentUser && r.nick === currentUser.nick;
    const dotsHTML = r.dots.map(d => {
      const cls = d==='e'?'d-exact':d==='t'?'d-tend':d==='w'?'d-wrong':'d-open';
      return `<span class="dot ${cls}"></span>`;
    }).join('');

    html += `<tr class="${isMe ? 'me-row' : ''}">
      <td class="rank-num ${cls}">${rankIcons[i] || rank}</td>
      <td>
        <div class="player-name-cell">${r.nick}${isMe?' <span style="color:var(--accent);font-size:12px">(Du)</span>':''}</div>
        <div class="player-alias">${r.info.vorname} ${r.info.nachname}</div>
      </td>
      <td class="pts-big">${r.punkte}</td>
      <td class="num-cell" style="color:var(--green)">${r.exakt}</td>
      <td class="num-cell" style="color:var(--blue)">${r.tendenz}</td>
      <td class="num-cell" style="color:var(--red)">${r.falsch}</td>
      <td><div class="dots-row">${dotsHTML}</div></td>
    </tr>`;
  });

  html += '</tbody></table>';
  bodyEl.innerHTML = html;
}

// ========================================================
// TIPPS
// ========================================================
async function loadTipps() {
  if (!currentUser) return;
  const container = document.getElementById('tipps-content');
  container.innerHTML = '<div class="empty"><h3>Lade...</h3></div>';

  const [myTipps, ergebnisse] = await Promise.all([
    dbGet('tipps/' + currentUser.nick),
    dbGet('ergebnisse'),
  ]);

  tippCache = myTipps || {};
  ergebnisseCache = ergebnisse || {};

  let filled = 0;
  ALL_SPIELE.forEach(s => {
    const t = tippCache[s.id] || {};
    if (t.h !== undefined && t.h !== '' && t.g !== undefined && t.g !== '') filled++;
  });

  document.getElementById('tipp-progress').style.display = '';
  document.getElementById('prog-fill').style.width = Math.round(filled / 48 * 100) + '%';
  document.getElementById('prog-count').textContent = `${filled} / 48`;

  let html = '';
  GRUPPEN.forEach(g => {
    html += `<div class="gruppe-header">
      <div class="gruppe-badge">${g.id}</div>
      <div class="gruppe-info">
        <h3>Gruppe ${g.id}</h3>
        <p>${g.teams.map(t => (FLAGS[t]||'🏳️') + ' ' + t).join(' &nbsp;·&nbsp; ')}</p>
      </div>
    </div>
    <div class="spiele-grid">`;

    g.spiele.forEach(s => {
      const t = tippCache[s.id] || {h:'', g:''};
      const e = ergebnisseCache[s.id];
      const locked = e !== undefined && e.h !== '' && e.g !== '';
      const hFlag = FLAGS[s.h] || '🏳️';
      const gFlag = FLAGS[s.g] || '🏳️';

      let statusHTML = '';
      let ergebnisHTML = '';
      if (locked) {
        const pts = calcPts({h: t.h, g: t.g}, {h: e.h, g: e.g});
        if (pts === 3) statusHTML = '<span class="status-badge sb-exact">✓ Exakt +3</span>';
        else if (pts === 1) statusHTML = '<span class="status-badge sb-tend">~ Tendenz +1</span>';
        else if (pts === 0) statusHTML = '<span class="status-badge sb-wrong">✗ Falsch +0</span>';
        ergebnisHTML = `<span class="ergebnis-display">Ergebnis: <strong>${e.h}:${e.g}</strong></span>`;
      }

      html += `<div class="spiel-card${locked?' locked':''}">
        <div class="spiel-top">
          <span class="spiel-meta">📅 ${s.d} ${s.z} Uhr &nbsp;|&nbsp; 📍 ${s.o}</span>
          <span class="locked-badge">🔒 Gesperrt</span>
        </div>
        <div class="spiel-teams">
          <div class="team-block home">
            <div class="team-n">${s.h}</div>
            <div class="team-flag">${hFlag}</div>
          </div>
          <div class="score-box${locked?' has-result':''}">
            <input class="score-inp" type="number" min="0" max="99"
              value="${t.h!==''&&t.h!==undefined?t.h:''}" placeholder="–"
              data-sid="${s.id}" data-side="h"
              ${locked?'disabled':''}
              oninput="onTippInput(this)">
            <span class="score-sep">:</span>
            <input class="score-inp" type="number" min="0" max="99"
              value="${t.g!==''&&t.g!==undefined?t.g:''}" placeholder="–"
              data-sid="${s.id}" data-side="g"
              ${locked?'disabled':''}
              oninput="onTippInput(this)">
          </div>
          <div class="team-block away">
            <div class="team-flag">${gFlag}</div>
            <div class="team-n">${s.g}</div>
          </div>
        </div>
        <div class="tipp-footer">${ergebnisHTML}${statusHTML}</div>
      </div>`;
    });

    html += '</div>';
  });

  container.innerHTML = html;
}

let tippSaveTimer = {};
function onTippInput(input) {
  const sid = input.dataset.sid;
  const side = input.dataset.side;
  const val = input.value === '' ? '' : Math.max(0, parseInt(input.value) || 0);
  if (input.value !== '' && val !== parseInt(input.value)) input.value = val;

  if (!tippCache[sid]) tippCache[sid] = {h:'', g:''};
  tippCache[sid][side] = val;

  clearTimeout(tippSaveTimer[sid]);
  tippSaveTimer[sid] = setTimeout(() => saveTipp(sid), 600);
}

async function saveTipp(sid) {
  if (!currentUser) return;
  const t = tippCache[sid];
  if (t.h === '' || t.g === '' || t.h === undefined || t.g === undefined) return;
  try {
    await dbUpdate('tipps/' + currentUser.nick, { [sid]: { h: +t.h, g: +t.g } });
    // Fortschritt aktualisieren
    let filled = 0;
    ALL_SPIELE.forEach(s => {
      const x = tippCache[s.id] || {};
      if (x.h !== '' && x.h !== undefined && x.g !== '' && x.g !== undefined) filled++;
    });
    document.getElementById('prog-fill').style.width = Math.round(filled/48*100)+'%';
    document.getElementById('prog-count').textContent = filled + ' / 48';
  } catch(e) {
    showToast('❌ Speichern fehlgeschlagen', 'error');
  }
}

// ========================================================
// ADMIN
// ========================================================
function doAdminLogin() {
  const pw = document.getElementById('admin-pw-input').value;
  const errEl = document.getElementById('admin-error');
  if (pw !== window._ADMIN_PASSWORD) {
    showErr(errEl, 'Falsches Passwort');
    return;
  }
  adminLoggedIn = true;
  document.getElementById('admin-login-wrap').style.display = 'none';
  document.getElementById('admin-content').style.display = '';
  document.getElementById('admin-nav-btn').style.display = '';
  loadAdminErgebnisse();
  showToast('✅ Admin eingeloggt', 'success');
}

function initAdminPage() {
  if (!adminLoggedIn) return;
  loadAdminErgebnisse();
}

async function loadAdminErgebnisse() {
  const grid = document.getElementById('admin-ergebnisse-grid');
  const ergebnisse = await dbGet('ergebnisse') || {};
  ergebnisseCache = ergebnisse;

  let html = '';
  GRUPPEN.forEach(g => {
    g.spiele.forEach(s => {
      const e = ergebnisse[s.id] || { h: '', g: '' };
      const saved = e.h !== '' && e.g !== '';
      html += `<div class="ergebnis-admin-card">
        <div class="era-top">
          <div>
            <div class="era-teams">
              <span>${FLAGS[s.h]||'🏳️'}</span> ${s.h}
              <span style="color:var(--text3)">vs</span>
              ${FLAGS[s.g]||'🏳️'} ${s.g}
            </div>
            <div class="era-meta">Gruppe ${g.id} &nbsp;|&nbsp; ${s.d} ${s.z} &nbsp;|&nbsp; ${s.o}</div>
          </div>
        </div>
        <div class="era-inputs">
          <div class="era-score-box">
            <input class="era-inp" type="number" min="0" max="99"
              id="ea-h-${s.id}" value="${saved?e.h:''}" placeholder="–">
            <span class="score-sep">:</span>
            <input class="era-inp" type="number" min="0" max="99"
              id="ea-g-${s.id}" value="${saved?e.g:''}" placeholder="–">
          </div>
          <button class="era-save-btn" onclick="saveAdminErgebnis('${s.id}')">Speichern</button>
          <span class="era-saved" id="era-saved-${s.id}">${saved?'✓ Gespeichert':''}</span>
        </div>
      </div>`;
    });
  });
  grid.innerHTML = html;
}

async function saveAdminErgebnis(sid) {
  const hVal = document.getElementById('ea-h-' + sid).value;
  const gVal = document.getElementById('ea-g-' + sid).value;
  if (hVal === '' || gVal === '') { showToast('Beide Felder ausfüllen', 'error'); return; }
  await dbUpdate('ergebnisse', { [sid]: { h: +hVal, g: +gVal } });
  const savedEl = document.getElementById('era-saved-' + sid);
  savedEl.style.display = 'inline';
  savedEl.textContent = '✓ Gespeichert';
  ergebnisseCache[sid] = { h: +hVal, g: +gVal };
  showToast('✅ Ergebnis gespeichert', 'success');
}

function adminTab(tab) {
  document.getElementById('admin-ergebnisse-wrap').style.display = tab === 'ergebnisse' ? '' : 'none';
  document.getElementById('admin-mitarbeiter-wrap').style.display = tab === 'mitarbeiter' ? '' : 'none';
  document.getElementById('atab-ergebnisse').classList.toggle('active', tab === 'ergebnisse');
  document.getElementById('atab-mitarbeiter').classList.toggle('active', tab === 'mitarbeiter');
  if (tab === 'mitarbeiter') loadMitarbeiter();
}

async function loadMitarbeiter() {
  const tbody = document.getElementById('mitarbeiter-tbody');
  const [spieler, alleTipps] = await Promise.all([dbGet('spieler'), dbGet('tipps')]);
  if (!spieler) { tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:var(--text2);padding:20px">Keine Spieler</td></tr>'; return; }

  let html = '';
  Object.entries(spieler).forEach(([nick, info], i) => {
    const tipps = alleTipps && alleTipps[nick] ? Object.keys(alleTipps[nick]).length : 0;
    const regDate = info.registriert ? new Date(info.registriert).toLocaleDateString('de-DE') : '-';
    html += `<tr>
      <td style="color:var(--text2);text-align:center">${i+1}</td>
      <td><strong>${nick}</strong></td>
      <td>${info.vorname}</td>
      <td>${info.nachname}</td>
      <td style="color:var(--text2);font-size:13px">${regDate}</td>
      <td style="text-align:center;color:var(--accent)">${tipps}</td>
      <td>
        <div style="display:flex;gap:6px">
          <button class="btn-sm" onclick="openEditMitarbeiter('${nick}','${info.vorname}','${info.nachname}')">✏️ Edit</button>
          <button class="btn-sm danger" onclick="deleteMitarbeiter('${nick}')">🗑️ Löschen</button>
        </div>
      </td>
    </tr>`;
  });
  tbody.innerHTML = html;
}

function openEditMitarbeiter(nick, vorname, nachname) {
  document.getElementById('edit-nick-key').value = nick;
  document.getElementById('edit-nick').value = nick;
  document.getElementById('edit-first').value = vorname;
  document.getElementById('edit-last').value = nachname;
  document.getElementById('edit-modal').classList.add('open');
}

async function saveEditMitarbeiter() {
  const oldNick = document.getElementById('edit-nick-key').value;
  const newNick = document.getElementById('edit-nick').value.trim();
  const vorname = document.getElementById('edit-first').value.trim();
  const nachname = document.getElementById('edit-last').value.trim();
  if (!newNick || !vorname || !nachname) { showToast('Alle Felder ausfüllen', 'error'); return; }

  await dbUpdate('spieler/' + oldNick, { vorname, nachname });
  closeModal();
  loadMitarbeiter();
  showToast('✅ Gespeichert', 'success');
}

async function deleteMitarbeiter(nick) {
  if (!confirm(`Mitarbeiter "${nick}" und alle Tipps löschen?`)) return;
  await dbSet('spieler/' + nick, null);
  await dbSet('tipps/' + nick, null);
  loadMitarbeiter();
  showToast('🗑️ Gelöscht', 'success');
}

function closeModal() { document.getElementById('edit-modal').classList.remove('open'); }

// ========================================================
// TOAST
// ========================================================
let toastTimer;
function showToast(msg, type = '') {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.className = 'show ' + type;
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => el.className = '', 2800);
}

// Click outside modal
document.getElementById('edit-modal').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});
</script>
